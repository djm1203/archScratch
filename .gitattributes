# Shell scripts and configs MUST use LF — CRLF breaks them on Linux.
*.sh        text eol=lf
*.bash      text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.toml      text eol=lf
*.css       text eol=lf
*.lst       text eol=lf
.zshrc      text eol=lf
.gitconfig  text eol=lf

# Scripts without an extension (installer entry + local-bin helpers).
install.sh           text eol=lf
local-bin/*          text eol=lf
Scripts/*            text eol=lf
system/*             text eol=lf
Configs/systemd/**   text eol=lf

# Binary assets — leave untouched.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
