# archScratch - mako notifications (Tokyo Night + Catppuccin accent)
# TO RECOLOR: change border-color (accent) to match the rest of the desktop.
font=Inter 11
background-color=#1a1b26
text-color=#c6d0f5
border-color=#cba6f7
border-size=2
border-radius=8
progress-color=over #cba6f7
padding=10
margin=8
width=360
height=120
icons=1
max-icon-size=48
default-timeout=3000
anchor=top-right

[urgency=low]
border-color=#6c7086

[urgency=high]
border-color=#e78284
default-timeout=0
