# archScratch - systemd services to enable
# One service per line
#
# Note: ASUS/NVIDIA-specific services are handled in pkg_install.sh:
#   power-profiles-daemon, nvidia-suspend/hibernate/resume, nvidia-powerd
#   asusd enables automatically via udev — no manual entry needed
#   tlp is disabled on ASUS machines (conflicts with power-profiles-daemon)

NetworkManager
bluetooth
docker
greetd
systemd-resolved
# Auto-trim the pacman package cache weekly (pacman-contrib)
paccache.timer
# Refresh fastest mirrors weekly (reflector)
reflector.timer
# Note: ufw is configured + enabled with rules in restore_svc.sh (setup_firewall)
